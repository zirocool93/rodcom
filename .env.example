COMPOSE_PROJECT_NAME=rodcom

DJANGO_ENV=production
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=change-me-generate-a-long-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

POSTGRES_DB=rodcom
POSTGRES_USER=rodcom
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://rodcom:change-me@postgres:5432/rodcom

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

BACKEND_PORT=8000
FRONTEND_API_BASE_URL=/api/v1

TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=http://backend:8000/api/v1
TELEGRAM_PROXY_ENABLED=false
TELEGRAM_PROXY_TYPE=socks5
TELEGRAM_PROXY_HOST=
TELEGRAM_PROXY_PORT=
TELEGRAM_PROXY_USERNAME=
TELEGRAM_PROXY_PASSWORD=

BACKUP_RETENTION_DAYS=14
BACKUP_DIR=/backups
